<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.Avalonia;assembly=LibVLCSharp.Avalonia"
        x:Class="MultiStreamVlc.MainWindow"
        Title="Multi Stream VLC — Grid View" Height="800" Width="1200"
        Background="#FF111111"
        Icon="avares://MultiStreamVlc/Assets/MultiStreamVLC.ico">

    <Grid Margin="8" x:Name="VideoGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Margin="6" CornerRadius="8" Background="#FF222222">
            <vlc:VideoView x:Name="V1"/>
        </Border>
        <Border Grid.Row="0" Grid.Column="1" Margin="6" CornerRadius="8" Background="#FF222222">
            <vlc:VideoView x:Name="V2"/>
        </Border>
        <Border Grid.Row="0" Grid.Column="2" Margin="6" CornerRadius="8" Background="#FF222222">
            <vlc:VideoView x:Name="V3"/>
        </Border>
        <Border Grid.Row="1" Grid.Column="0" Margin="6" CornerRadius="8" Background="#FF222222">
            <vlc:VideoView x:Name="V4"/>
        </Border>
        <Border Grid.Row="1" Grid.Column="1" Margin="6" CornerRadius="8" Background="#FF222222">
            <vlc:VideoView x:Name="V5"/>
        </Border>
        <Border Grid.Row="1" Grid.Column="2" Margin="6" CornerRadius="8" Background="#FF222222">
            <vlc:VideoView x:Name="V6"/>
        </Border>
    </Grid>
</Window>
